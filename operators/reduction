module tb;
  logic [3:0] a ;
  task automatic display();
    begin
      $display("reduction and &a  = %0d ",&a);
      $display("reduction or |a  = %0d ",|a);
      $display("reduction exor ^a  = %0d ",^a);
      $display("reduction nand ~&a  = %0d ",~&a);
      $display("reduction NOR ~|a  = %0d ",~|a);
      $display("reduction exnor ~^a  = %0d ",~^a);
    end
      endtask
  initial begin
    a=4'b1010;
    display();
  end
endmodule
